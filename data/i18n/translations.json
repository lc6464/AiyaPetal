    "page.about.metaTitle": {
      "zh-Hans": "关于我们",
      "zh-Hant": "關於我們",
      "en": "About"
    },
    "page.about.eyebrow": {
      "zh-Hans": "About EleFlower",
      "zh-Hant": "About EleFlower",
      "en": "About EleFlower"
    },
    "page.about.title": {
      "zh-Hans": "把押花构图搬到浏览器中",
      "zh-Hant": "把押花構圖搬到瀏覽器中",
      "en": "Bring Pressed Flower Composition Into the Browser"
    },
    "page.about.lead": {
      "zh-Hans": "云押花服务于电子押花排版、教学演示和材料试样阶段，让真实花材在进入纸面前，先完成一轮高效率的数字构图。",
      "zh-Hant": "雲押花服務於電子押花排版、教學展示和材料試樣階段，讓真實花材在進入紙面前，先完成一輪高效率的數位構圖。",
      "en": "EleFlower supports digital composition, teaching demos, and material trials so real flowers can be arranged efficiently before they ever reach paper."
    },
    "page.about.card1.title": {
      "zh-Hans": "设计原则",
      "zh-Hant": "設計原則",
      "en": "Design Principles"
    },
    "page.about.card1.body": {
      "zh-Hans": "优先保留手工押花的层次感与留白逻辑，用轻量化 2D 编辑器代替笨重的图像处理流程。",
      "zh-Hant": "優先保留手工押花的層次感與留白邏輯，用輕量化 2D 編輯器取代笨重的影像處理流程。",
      "en": "It preserves the layering and whitespace logic of hand-crafted pressed flowers while replacing heavy image editors with a focused 2D workflow."
    },
    "page.about.card2.title": {
      "zh-Hans": "技术策略",
      "zh-Hant": "技術策略",
      "en": "Technical Strategy"
    },
    "page.about.card2.body": {
      "zh-Hans": "站点采用现代浏览器基线、ES Modules、Import Map 与 Konva，强调清晰结构与低维护成本。",
      "zh-Hant": "站點採用現代瀏覽器基線、ES Modules、Import Map 與 Konva，強調清晰結構與低維護成本。",
      "en": "The site is built on a modern browser baseline with ES modules, import maps, and Konva for a clear structure and low maintenance cost."
    },
    "page.about.card3.title": {
      "zh-Hans": "适用场景",
      "zh-Hant": "適用場景",
      "en": "Use Cases"
    },
    "page.about.card3.body": {
      "zh-Hans": "适合花艺课程、文创打样、纪念花册排版和线上协作前的快速构图讨论。",
      "zh-Hant": "適合花藝課程、文創打樣、紀念花冊排版和線上協作前的快速構圖討論。",
      "en": "It fits floral classes, cultural product mockups, memorial albums, and fast pre-collaboration composition reviews."
    },
    "page.gallery.metaTitle": {
      "zh-Hans": "作品展示",
      "zh-Hant": "作品展示",
      "en": "Gallery"
    },
    "page.gallery.eyebrow": {
      "zh-Hans": "Gallery",
      "zh-Hant": "Gallery",
      "en": "Gallery"
    },
    "page.gallery.title": {
      "zh-Hans": "构图方向示例",
      "zh-Hant": "構圖方向示例",
      "en": "Composition Directions"
    },
    "page.gallery.lead": {
      "zh-Hans": "这里展示的是几种适合在电子押花编辑台中快速试排的构图逻辑，帮助使用者从素材开始而不是从空白画布开始。",
      "zh-Hant": "這裡展示的是幾種適合在電子押花編輯台中快速試排的構圖邏輯，幫助使用者從素材開始而不是從空白畫布開始。",
      "en": "These examples show composition patterns that work well in the editor, helping people start from material logic instead of from a blank canvas."
    },
    "page.gallery.card1.title": {
      "zh-Hans": "单枝留白",
      "zh-Hant": "單枝留白",
      "en": "Single Stem"
    },
    "page.gallery.card1.body": {
      "zh-Hans": "以一朵主花搭配少量叶材，让背景纹理承担更多视觉呼吸感。",
      "zh-Hant": "以一朵主花搭配少量葉材，讓背景紋理承擔更多視覺呼吸感。",
      "en": "Use one main bloom with only a little foliage so the background texture carries more of the breathing space."
    },
    "page.gallery.card2.title": {
      "zh-Hans": "对角生长",
      "zh-Hant": "對角生長",
      "en": "Diagonal Growth"
    },
    "page.gallery.card2.body": {
      "zh-Hans": "使用叶片先建立斜向路径，再在交点堆叠不同尺寸的花朵，构成流动式布局。",
      "zh-Hant": "使用葉片先建立斜向路徑，再在交點堆疊不同尺寸的花朵，構成流動式佈局。",
      "en": "Build a diagonal path with foliage first, then stack blooms of different sizes along the intersections for a flowing layout."
    },
    "page.gallery.card3.title": {
      "zh-Hans": "簇状聚焦",
      "zh-Hant": "簇狀聚焦",
      "en": "Cluster Focus"
    },
    "page.gallery.card3.body": {
      "zh-Hans": "在中心区域连续复制并细调角度，用重复节奏做出花束感与密度变化。",
      "zh-Hant": "在中心區域連續複製並微調角度，用重複節奏做出花束感與密度變化。",
      "en": "Duplicate and fine-tune angles near the center to create bouquet-like rhythm and density changes."
    },
